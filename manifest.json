{
  "manifest_version": 3,
  "name": "__MSG_extName__",
  "version": "3.2.0",
  "description": "__MSG_extDesc__",
  "default_locale": "ko",
  "author": "Junha Baek",
  "permissions": [
    "storage",
    "tabs",
    "scripting"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "action": {
    "default_title": "__MSG_extName__",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "images/icon16.png",
      "32": "images/icon32.png",
      "48": "images/icon48.png"
    }
  },
  "icons": {
    "16": "images/icon16.png",
    "32": "images/icon32.png",
    "48": "images/icon48.png",
    "128": "images/icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["js/ai-repair.js", "content_script.js"],
      "all_frames": true
    }
  ],
  "homepage_url": "https://baekjunha.github.io/"
}